# ============================================================
# Corpus — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# SQLite (zero-config, great for local dev and small self-hosters)
DATABASE_URL=sqlite:///./corpus_dev.db

# PostgreSQL example (for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/corpus_db

# ── JWT Authentication ────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=corpus_dev_secret_key_change_me_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── AI & RAG Engine (Google Gemini) ──────────────────────────
# Get a free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
