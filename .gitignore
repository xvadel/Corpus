# =============================================================
# Corpus — .gitignore
# =============================================================

# ── IDE & Editor ──────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws
.history/
.project
.classpath
.settings/

# ── OS Files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Frontend Build Artifacts ──────────────────────────────────
/frontend/node_modules/
/frontend/dist/
/frontend/.svelte-kit/

# ── Backend — Compiled Static Assets (built by Dockerfile) ───
/backend/static/

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Alembic — keep versions folder but ignore local state ─────
# alembic/versions/*.py   # Uncomment if you want to ignore migrations

# ── Databases & Local Storage ─────────────────────────────────
*.db
*.sqlite3
corpus_dev.db

# ── Environment Variables (NEVER commit secrets) ──────────────
.env

# ── Logs ──────────────────────────────────────────────────────
*.log
*.log.*

# ── RAG / Vector DB artifacts ─────────────────────────────────
/rag/chroma_db/
/rag/*.pkl

# ── Tests cache ───────────────────────────────────────────────
/tests/.pytest_cache/
/tests/__pycache__/
htmlcov/
.coverage